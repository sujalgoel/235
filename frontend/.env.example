# Frontend environment template. Copy to .env.local for local dev or set in deploy env.

# Base URL the browser uses to reach the backend.
# Local dev: leave unset to default to http://localhost:8000/api/v1
# Production: set to the deployed backend, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=

# Vite dev-server proxy target. Used only by `vite dev`.
VITE_PROXY_TARGET=
