# ========================================
# Backend environment template
# ========================================
# Copy this file to .env and fill in real values for local development.
# Never commit a .env file with real secrets. (.env is gitignored.)

# ========================================
# ENVIRONMENT
# ========================================
ENVIRONMENT=development

# ========================================
# MODEL PATHS
# ========================================
IMAGE_MODEL_PATH=models/image/resnet18_v1.0.pth
TEXT_MODEL_PATH=models/text/distilbert_v1.0

# ========================================
# DEVICE
# ========================================
# cpu or cuda
DEVICE=cpu

# ========================================
# API SERVER
# ========================================
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins. Required in production.
# Local dev is covered by the safe default in config/base.py.
# CORS_ORIGINS=https://your-frontend.example.com

# ========================================
# FUSION WEIGHTS (must sum to 1.0)
# ========================================
IMAGE_WEIGHT=0.4
TEXT_WEIGHT=0.3
METADATA_WEIGHT=0.3

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO

# ========================================
# ENSEMBLE MODE
# ========================================
# When true, use the local ensemble (EfficientNet-B7 + XceptionNet + CLIP for
# images; ChatGPT-detector + OpenAI-detector + rules for text). When false,
# fall back to a single-model pipeline (ResNet-18 + DistilBERT). Despite the
# legacy name, neither path makes external API calls.
USE_CLOUD_APIS=true
