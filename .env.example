# Backend environment template. Copy to .env for local development.
# Never commit a populated .env (.env is gitignored).

ENVIRONMENT=development

# Model paths (auto-created on first run)
IMAGE_MODEL_PATH=models/image/resnet18_v1.0.pth
TEXT_MODEL_PATH=models/text/distilbert_v1.0

# Device: cpu or cuda
DEVICE=cpu

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allowed CORS origins. Required in production; local dev
# uses a safe default in config/base.py.
# CORS_ORIGINS=https://your-frontend.example.com

# Fusion weights (must sum to 1.0)
IMAGE_WEIGHT=0.4
TEXT_WEIGHT=0.3
METADATA_WEIGHT=0.3

LOG_LEVEL=INFO
